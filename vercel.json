{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60,
        "memory": 1024
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH"]
    }
  ],
  "functions": {
    "api/generate-v2.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/image-v2.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/export.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/batch.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
