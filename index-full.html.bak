<!-- ========== JS ========== -->
<script>
/* ============================================================
   TESTIMONIAL MARQUEE — 6 SVG face avatars + 2 infinite rows
   ============================================================ */
const testimonials = [
  {
    stars: '★★★★★',
    quote: '"My Pinterest traffic tripled in two months. I used to spend hours scheduling manually — now it\'s completely hands-off."',
    name: 'Sophie L.',
    role: 'Lifestyle blogger · 52K followers',
    avatar: ``
  },
  {
    stars: '★★★★★',
    quote: '"The AI descriptions alone are worth it. They rank so much better than what I was writing myself, and they sound genuinely good."',
    name: 'Mia C.',
    role: 'eCommerce store · Etsy seller',
    avatar: ``
  },
  {
    stars: '★★★★★',
    quote: '"Managing 12 client accounts from one dashboard used to feel impossible. PinFlow made it effortless. Agency plan is a steal."',
    name: 'Jamie R.',
    role: 'Social media agency · 12 clients',
    avatar: ``
  },
  {
    stars: '★★★★★',
    quote: '"I make more from my affiliate links now than from my day job. PinFlow keeps my product pins circulating 24/7 — I literally earn while I sleep."',
    name: 'Tara K.',
    role: 'Affiliate marketer · Amazon Associates',
    avatar: ``
  },
  {
    stars: '★★★★★',
    quote: '"I cut my Pinterest work time from 6 hours a week to under 30 minutes. That\'s time I now spend making new content — and my revenue went up 80%."',
    name: 'Natasha B.',
    role: 'Food blogger · 110K monthly views',
    avatar: ``
  },
  {
    stars: '★★★★★',
    quote: '"I connected my Shopify store feed on a Tuesday. By Friday I had sales coming in from pins I never even manually created. Still feels like magic."',
    name: 'Daniel W.',
    role: 'Shopify store owner · Home decor',
    avatar: ``
  }
];

function buildTestiCard(t) {
  const card = document.createElement('div');
  card.className = 'testi-card';
  card.innerHTML = `
    <div class="testi-stars">${t.stars}</div>
    <p class="testi-quote">${t.quote}</p>
    <div class="testi-author">
      <div class="testi-avatar">${t.avatar}</div>
      <div>
        <div class="testi-name">${t.name}</div>
        <div class="testi-role">${t.role}</div>
      </div>
    </div>`;
  return card;
}

function buildTestiRow(indices, trackId) {
  const track = document.getElementById(trackId);
  if (!track) return;
  const doubled = [...indices, ...indices];
  doubled.forEach(i => track.appendChild(buildTestiCard(testimonials[i])));
}

buildTestiRow([0,1,2,3], 'trow1');
buildTestiRow([2,3,4,5], 'trow2');

/* ============================================================
   PLATFORM CAROUSEL — build chips with inline SVG logos
   ============================================================ */
const platforms = [
  {
    name: 'Shopify',
    color: '#96BF48',
    svg: ``
  },
  {
    name: 'Amazon',
    color: '#FF9900',
    svg: ``
  },
  {
    name: 'Etsy',
    color: '#F1641E',
    svg: ``
  },
  {
    name: 'WooCommerce',
    color: '#7F54B3',
    svg: ``
  },
  {
    name: 'eBay',
    color: '#E53238',
    svg: ``
  },
  {
    name: 'Pinterest Shop',
    color: '#E60023',
    svg: ``
  },
  {
    name: 'BigCommerce',
    color: '#34313F',
    svg: ``
  },
  {
    name: 'Squarespace',
    color: '#000',
    svg: ``
  },
  {
    name: 'ASOS',
    color: '#2F1A45',
    svg: ``
  },
  {
    name: 'Redbubble',
    color: '#E41321',
    svg: ``
  },
  {
    name: 'Rakuten',
    color: '#BF0000',
    svg: ``
  },
  {
    name: 'ShareASale',
    color: '#1A7FBF',
    svg: ``
  },
];

/* Split into two rows */
const row1 = platforms.slice(0, 7);
const row2 = platforms.slice(5).concat(platforms.slice(0, 5));

function buildRow(items, trackId) {
  const track = document.getElementById(trackId);
  if (!track) return;
  /* Duplicate set for infinite loop */
  const full = [...items, ...items];
  full.forEach(p => {
    const chip = document.createElement('div');
    chip.className = 'platform-chip';
    chip.innerHTML = p.svg + `<span>${p.name}</span>`;
    track.appendChild(chip);
  });
}

buildRow(row1, 'row1');
buildRow(row2, 'row2');

/* Pricing toggle */
const tgl   = document.getElementById('bill-tgl');
const track = document.getElementById('tgl-track');
const thumb = document.getElementById('tgl-thumb');
const lblM  = document.getElementById('lbl-m');
const lblA  = document.getElementById('lbl-a');
const mo = { starter:19, pro:49, agency:99 };
const yr = { starter:15, pro:39, agency:79 };

function setPricing(annual) {
  const p = annual ? yr : mo;
  ['starter','pro','agency'].forEach(k => {
    document.getElementById('p-' + k).textContent = p[k];
    const el = document.getElementById('orig-' + k);
    if (annual) { el.textContent = 'was $' + mo[k] + '/mo'; el.style.display = 'block'; }
    else el.style.display = 'none';
  });
  track.classList.toggle('on', annual);
  thumb.classList.toggle('on', annual);
  lblM.classList.toggle('active', !annual);
  lblA.classList.toggle('active', annual);
}
tgl.addEventListener('change', () => setPricing(tgl.checked));

/* FAQ accordion */
document.querySelectorAll('.faq-item').forEach(item => {
  item.querySelector('.faq-q').addEventListener('click', () => {
    const was = item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
    if (!was) item.classList.add('open');
  });
});
</script>

</body>
</html>
