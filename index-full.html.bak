<!-- ========== FEATURES ========== -->
<section class="section features-section" id="features">
  <div class="container">
    <div class="center">
      <div class="eyebrow">What's inside</div>
      <h2 class="h2">Everything a creator needs<br>to <em>grow on Pinterest</em></h2>
      <p class="sub" style="margin: 0 auto;">One platform to schedule, automate, analyze, and grow — no technical skills required.</p>
    </div>
    <div class="features-grid">
      <div class="feat-card">
        <div class="feat-icon">📌</div>
        <div class="feat-title">Smart Pin Scheduling</div>
        <p class="feat-desc">Queue unlimited pins across all your boards. Post at peak times based on your audience's activity patterns.</p>
      </div>
      <div class="feat-card">
        <div class="feat-icon">✨</div>
        <div class="feat-title">AI Description Generator</div>
        <p class="feat-desc">Drop in an image or URL and get SEO-rich pin titles and descriptions written instantly — no copywriting needed.</p>
      </div>
      <div class="feat-card">
        <div class="feat-icon">📊</div>
        <div class="feat-title">Deep Analytics</div>
        <p class="feat-desc">See impressions, saves, clicks, and revenue per pin. Know exactly which content is driving your traffic.</p>
      </div>
      <div class="feat-card">
        <div class="feat-icon">🔁</div>
        <div class="feat-title">RSS → Pinterest</div>
        <p class="feat-desc">Connect your blog or shop feed. New posts automatically become pins the moment they're published.</p>
      </div>
      <div class="feat-card">
        <div class="feat-icon">🎯</div>
        <div class="feat-title">Keyword Optimizer</div>
        <p class="feat-desc">AI weaves high-traffic Pinterest keywords into every description to maximize search discoverability.</p>
      </div>
      <div class="feat-card">
        <div class="feat-icon">⚡</div>
        <div class="feat-title">Bulk Upload</div>
        <p class="feat-desc">Upload hundreds of pins via CSV or ZIP in seconds. Set boards, captions, and schedules all at once.</p>
      </div>
    </div>
  </div>
</section>

<!-- ========== VALUE PROPS ========== -->
<section class="value-section" id="why-pinflow">
  <div class="container">
    <div class="center">
      <div class="eyebrow">Why PinFlow</div>
      <h2 class="h2">Three reasons creators<br><em>can't stop</em> using it</h2>
      <p class="sub" style="margin: 0 auto;">Built for the creator economy — where time, reach, and passive revenue all matter.</p>
    </div>
    <div class="value-grid">

      <!-- 1. Efficiency -->
      <div class="value-card v1">
        <div class="value-icon-wrap">
          
        </div>
        <div class="value-num">10×</div>
        <div class="value-title">Save hours every week</div>
        <p class="value-body">What used to take a full afternoon — writing captions, picking boards, timing posts — happens automatically. Set a queue once, and PinFlow handles every pin for months without you lifting a finger.</p>
      </div>

      <!-- 2. Affiliate -->
      <div class="value-card v2">
        <div class="value-icon-wrap">
          
        </div>
        <div class="value-num">Built-in</div>
        <div class="value-title">Your affiliate marketing engine</div>
        <p class="value-body">Pinterest is the highest-converting social platform for product links. PinFlow is purpose-built for affiliate marketers — embed tracking links, rotate product pins, and watch commissions stack while your content spreads organically.</p>
      </div>

      <!-- 3. Passive income -->
      <div class="value-card v3">
        <div class="value-icon-wrap">
          
        </div>
        <div class="value-num">24/7</div>
        <div class="value-title">Earns while you sleep</div>
        <p class="value-body">Pinterest pins have a half-life of months, not hours. PinFlow keeps your content recycling and your links active around the clock — turning a post you made on Tuesday into revenue the following Sunday.</p>
      </div>

    </div>
  </div>
</section>

<!-- ========== PRICING ========== -->
