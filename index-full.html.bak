<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PinFlow — Pinterest Automation for Creators</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;1,700&family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ============================================================
   DESIGN TOKENS  —  cream / blush / editorial
   ============================================================ */
:root {
  --cream:       #FEFAF7;
  --cream-2:     #FAF3ED;
  --cream-3:     #F3E6DE;
  --white:       #FFFFFF;
  --bdr:         rgba(175, 118, 96, 0.13);
  --bdr-hi:      rgba(175, 118, 96, 0.24);
  --red:         #C8344A;
  --red-h:       #B02A3D;
  --red-soft:    rgba(200, 52, 74, 0.07);
  --blush:       #FAE5E9;
  --blush-2:     #F5CDD4;
  --rose:        #E8A4AE;
  --petal:       #FDF1F3;
  --shadow:      rgba(160, 90, 80, 0.08);
  --shadow-card: 0 4px 28px rgba(160, 90, 80, 0.09);
  --t1:          #261620;
  --t2:          #7A5860;
  --t3:          #B89EA4;
  --serif:       'Playfair Display', Georgia, serif;
  --sans:        'Nunito', -apple-system, sans-serif;
  --r-sm:        10px;
  --r-md:        16px;
  --r-lg:        22px;
  --r-xl:        30px;
}

/* ============================================================
   RESET & BASE
   ============================================================ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: var(--sans);
  background: var(--cream);
  color: var(--t1);
  line-height: 1.65;
  font-size: 15px;
  -webkit-font-smoothing: antialiased;
}
a { color: inherit; text-decoration: none; }
ul { list-style: none; }
.container { max-width: 1140px; margin: 0 auto; padding: 0 28px; }
.section { padding: 88px 0; }
.center { text-align: center; }

/* ============================================================
   TYPOGRAPHY HELPERS
   ============================================================ */
.eyebrow {
  display: inline-block;
  font-family: var(--sans);
  font-size: 11.5px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: 16px;
}
.h2 {
  font-family: var(--serif);
  font-size: clamp(28px, 4vw, 44px);
  font-weight: 800;
  line-height: 1.18;
  letter-spacing: -0.01em;
  color: var(--t1);
  margin-bottom: 16px;
}
.h2 em { font-style: italic; color: var(--red); }
.sub {
  font-size: 16.5px;
  color: var(--t2);
  line-height: 1.68;
  max-width: 520px;
}

/* ============================================================
   BUTTONS
   ============================================================ */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-family: var(--sans);
  font-weight: 700;
  font-size: 14px;
  padding: 11px 24px;
  border-radius: 100px;
  cursor: pointer;
  border: none;
  transition: all 0.18s ease;
  white-space: nowrap;
  letter-spacing: 0.01em;
}
.btn-sm  { font-size: 13px; padding: 8px 18px; }
.btn-lg  { font-size: 15.5px; padding: 15px 34px; }

.btn-primary {
  background: var(--red);
  color: #fff;
  box-shadow: 0 4px 18px rgba(200,52,74,0.28);
}
.btn-primary:hover { background: var(--red-h); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(200,52,74,0.34); }

.btn-soft {
  background: var(--blush);
  color: var(--red);
  border: 1.5px solid var(--blush-2);
}
.btn-soft:hover { background: var(--blush-2); transform: translateY(-1px); }

.btn-outline {
  background: transparent;
  color: var(--t1);
  border: 1.5px solid var(--bdr-hi);
}
.btn-outline:hover { border-color: var(--rose); color: var(--red); background: var(--petal); }

.btn-ghost {
  background: transparent;
  color: var(--t2);
}
.btn-ghost:hover { color: var(--t1); background: var(--cream-2); }

/* ============================================================
   PROMO BANNER  —  soft blush, not heavy
   ============================================================ */
.promo-bar {
  background: var(--blush);
  border-bottom: 1px solid var(--blush-2);
  text-align: center;
  padding: 10px 20px;
  font-size: 13px;
  font-weight: 600;
  color: var(--red);
}
.promo-bar code {
  background: rgba(200,52,74,0.12);
  padding: 2px 9px;
  border-radius: 5px;
  font-family: var(--sans);
  letter-spacing: 0.07em;
  margin: 0 4px;
}
.promo-bar a { text-decoration: underline; margin-left: 10px; opacity: .8; }
.promo-bar a:hover { opacity: 1; }

/* ============================================================
   NAVBAR
   ============================================================ */
.navbar {
  position: sticky;
  top: 0;
  z-index: 200;
  background: rgba(254,250,247,0.90);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--bdr);
}
.nav-wrap {
  display: flex;
  align-items: center;
  height: 62px;
  gap: 6px;
}
.logo {
  display: flex;
  align-items: center;
  gap: 9px;
  font-family: var(--serif);
  font-weight: 700;
  font-size: 20px;
  color: var(--t1);
  margin-right: 28px;
  flex-shrink: 0;
  letter-spacing: -0.01em;
}
.logo-mark {
  width: 31px;
  height: 31px;
  background: var(--red);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.logo-mark svg { width: 17px; height: 17px; fill: #fff; }

.nav-links { display: flex; align-items: center; gap: 2px; flex: 1; }
.nav-links a {
  font-size: 14px;
  font-weight: 600;
  color: var(--t2);
  padding: 6px 13px;
  border-radius: 100px;
  transition: color 0.15s, background 0.15s;
}
.nav-links a:hover, .nav-links a.active { color: var(--t1); background: var(--cream-2); }

.nav-actions { display: flex; align-items: center; gap: 8px; }

/* ============================================================
   HERO SECTION
   ============================================================ */
.hero {
  padding: 100px 0 72px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
/* Soft decorative circles — pure CSS */
.hero::before {
  content: '';
  position: absolute;
  top: -80px; right: -80px;
  width: 440px; height: 440px;
  background: var(--blush);
  border-radius: 50%;
  opacity: 0.55;
  pointer-events: none;
}
.hero::after {
  content: '';
  position: absolute;
  bottom: 0; left: -60px;
  width: 280px; height: 280px;
  background: var(--cream-3);
  border-radius: 50%;
  opacity: 0.6;
  pointer-events: none;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--petal);
  border: 1.5px solid var(--blush-2);
  color: var(--red);
  font-size: 12.5px;
  font-weight: 700;
  padding: 6px 18px;
  border-radius: 100px;
  margin-bottom: 32px;
  letter-spacing: 0.01em;
}
.hero-badge .pulse {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--red);
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: .5; transform: scale(0.7); }
}

.hero-title {
  font-family: var(--serif);
  font-size: clamp(42px, 7vw, 78px);
  font-weight: 800;
  line-height: 1.08;
  letter-spacing: -0.02em;
  max-width: 820px;
  margin: 0 auto 22px;
  color: var(--t1);
  position: relative;
  z-index: 1;
}
.hero-title em { font-style: italic; color: var(--red); }

.hero-sub {
  font-size: clamp(15.5px, 2vw, 18.5px);
  color: var(--t2);
  max-width: 500px;
  margin: 0 auto 40px;
  line-height: 1.68;
  position: relative;
  z-index: 1;
}

.hero-ctas { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; position: relative; z-index: 1; }
.hero-note { margin-top: 14px; font-size: 12.5px; color: var(--t3); position: relative; z-index: 1; }

/* Pinterest-style pin grid preview */
.pin-preview {
  margin: 64px auto 0;
  max-width: 860px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
  position: relative;
  z-index: 1;
  border-radius: var(--r-xl);
  overflow: hidden;
  border: 1px solid var(--bdr);
  padding: 14px;
  background: var(--white);
  box-shadow: var(--shadow-card);
}
.pin-col { display: flex; flex-direction: column; gap: 10px; }
.pin-tile {
  border-radius: 14px;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
  padding: 10px;
}
.pin-tile .pin-label {
  font-size: 11px;
  font-weight: 700;
  color: rgba(0,0,0,0.45);
  background: rgba(255,255,255,0.72);
  padding: 3px 8px;
  border-radius: 100px;
  backdrop-filter: blur(4px);
}
.pin-h1 { height: 180px; }
.pin-h2 { height: 120px; }
.pin-h3 { height: 150px; }
.pin-h4 { height: 100px; }
.pin-h5 { height: 210px; }
/* Pin color palettes — soft pastels */
.pc-blush  { background: #FADDE1; }
.pc-lav    { background: #E8E0F5; }
.pc-sage   { background: #D9EDE0; }
.pc-peach  { background: #FDEBD8; }
.pc-sky    { background: #DBE8F5; }
.pc-lilac  { background: #F2D9F5; }
.pc-mint   { background: #D9F5EC; }
.pc-butter { background: #FDF5D0; }
.pc-rose   { background: #F5D9E0; }

/* Pin scheduling overlay on one tile */
.pin-sched {
  position: absolute; inset: 0;
  background: rgba(200,52,74,0.88);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 4px;
  border-radius: 14px;
}
.sched-icon { font-size: 22px; }
.sched-text { font-size: 11px; font-weight: 700; color: white; letter-spacing: 0.04em; }

/* ============================================================
   STATS BAR
   ============================================================ */
.stats-bar {
  background: var(--white);
  border-top: 1px solid var(--bdr);
  border-bottom: 1px solid var(--bdr);
  padding: 44px 0;
}
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32px;
  text-align: center;
}
.stat-divider {
  border-right: 1px solid var(--bdr);
}
.stat-num {
  font-family: var(--serif);
  font-size: 36px;
  font-weight: 800;
  line-height: 1;
  margin-bottom: 7px;
  color: var(--t1);
}
.stat-num .hi { color: var(--red); }
.stat-lbl { font-size: 13px; color: var(--t2); font-weight: 600; }

/* ============================================================
   FEATURES
   ============================================================ */
.features-section { background: var(--cream-2); }

.features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
  margin-top: 56px;
}
.feat-card {
  background: var(--white);
  border: 1px solid var(--bdr);
  border-radius: var(--r-lg);
  padding: 32px 28px;
  transition: box-shadow 0.2s, transform 0.2s;
}
.feat-card:hover {
  box-shadow: var(--shadow-card);
  transform: translateY(-3px);
}
.feat-icon {
  width: 44px;
  height: 44px;
  background: var(--blush);
  border-radius: var(--r-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  margin-bottom: 18px;
}
.feat-title {
  font-family: var(--serif);
  font-size: 17px;
  font-weight: 700;
  margin-bottom: 9px;
  color: var(--t1);
}
.feat-desc { font-size: 13.5px; color: var(--t2); line-height: 1.68; }

/* ============================================================
   PRICING
   ============================================================ */
.pricing-section { background: var(--cream); }

/* Toggle */
.billing-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 13px;
  margin: 36px 0 52px;
}
.t-label { font-size: 14px; font-weight: 700; color: var(--t3); cursor: pointer; user-select: none; transition: color .15s; }
.t-label.active { color: var(--t1); }
.t-switch { position: relative; width: 50px; height: 27px; cursor: pointer; }
.t-switch input { opacity: 0; width: 0; height: 0; position: absolute; }
.t-track {
  position: absolute; inset: 0;
  background: var(--cream-3);
  border: 1.5px solid var(--bdr-hi);
  border-radius: 100px;
  transition: background .2s, border-color .2s;
}
.t-track.on { background: var(--red); border-color: var(--red); }
.t-thumb {
  position: absolute; top: 3px; left: 3px;
  width: 19px; height: 19px;
  background: white;
  border-radius: 50%;
  box-shadow: 0 1px 4px rgba(0,0,0,0.18);
  transition: transform .22s ease;
}
.t-thumb.on { transform: translateX(23px); }
.save-badge {
  font-size: 11.5px; font-weight: 700;
  color: #16a34a;
  background: rgba(22,163,74,0.10);
  border: 1.5px solid rgba(22,163,74,0.22);
  padding: 3px 12px; border-radius: 100px;
}

/* Pricing cards */
.pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }

.price-card {
  background: var(--white);
  border: 1.5px solid var(--bdr);
  border-radius: var(--r-xl);
  padding: 36px 30px;
  transition: box-shadow .2s, transform .2s;
  position: relative;
}
.price-card:hover { box-shadow: var(--shadow-card); transform: translateY(-3px); }
.price-card.featured {
  border: 2px solid var(--red);
  background: linear-gradient(165deg, var(--petal) 0%, var(--white) 42%);
}
.popular-pill {
  position: absolute; top: 20px; right: 20px;
  background: var(--red);
  color: white;
  font-size: 10.5px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.09em;
  padding: 4px 13px; border-radius: 100px;
}

.plan-name { font-family: var(--serif); font-size: 20px; font-weight: 700; margin-bottom: 5px; color: var(--t1); }
.plan-tagline { font-size: 13px; color: var(--t2); margin-bottom: 26px; }

.plan-price { margin-bottom: 26px; }
.price-row { display: flex; align-items: flex-start; gap: 2px; line-height: 1; }
.price-dollar { font-family: var(--serif); font-size: 22px; font-weight: 700; margin-top: 9px; color: var(--t1); }
.price-amount { font-family: var(--serif); font-size: 56px; font-weight: 800; letter-spacing: -0.03em; color: var(--t1); }
.price-freq { font-size: 13px; color: var(--t2); margin-top: 7px; }
.price-cross { font-size: 13px; color: var(--t3); text-decoration: line-through; margin-top: 3px; }

.plan-btn {
  display: block; width: 100%; text-align: center;
  padding: 13.5px; border-radius: 100px;
  font-size: 14.5px; font-weight: 700;
  cursor: pointer; border: none;
  transition: all .18s; margin-bottom: 28px;
  letter-spacing: 0.01em;
}
.plan-btn-fill {
  background: var(--red); color: white;
  box-shadow: 0 4px 18px rgba(200,52,74,0.26);
}
.plan-btn-fill:hover { background: var(--red-h); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(200,52,74,0.32); }
.plan-btn-soft {
  background: var(--cream-2); color: var(--t1);
  border: 1.5px solid var(--bdr-hi);
}
.plan-btn-soft:hover { background: var(--cream-3); }

.plan-divider { border: none; border-top: 1px solid var(--bdr); margin-bottom: 24px; }
.plan-feats { display: flex; flex-direction: column; gap: 12px; }
.feat-row { display: flex; align-items: flex-start; gap: 10px; font-size: 13.5px; color: var(--t2); }
.fi {
  width: 18px; height: 18px; border-radius: 50%; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; margin-top: 1px;
}
.fi-yes { background: rgba(22,163,74,0.13); color: #16a34a; }
.fi-no  { background: var(--cream-3); color: var(--t3); }
.feat-off { color: var(--t3); }

/* ============================================================
   COMPARISON TABLE
   ============================================================ */
.cmp-wrap { overflow-x: auto; }
.cmp-table { width: 100%; border-collapse: collapse; margin-top: 44px; }
.cmp-table th, .cmp-table td {
  padding: 14px 18px; text-align: left;
  border-bottom: 1px solid var(--bdr); font-size: 13.5px;
}
.cmp-table thead th {
  font-family: var(--sans); font-size: 13px; font-weight: 700;
  background: var(--cream-2); color: var(--t2);
  letter-spacing: 0.01em;
}
.cmp-table thead th:first-child { border-radius: 12px 0 0 0; }
.cmp-table thead th:last-child  { border-radius: 0 12px 0 0; }
.cmp-table tbody td { color: var(--t2); }
.cmp-table tbody tr:hover td { background: var(--petal); }
.tc { text-align: center; }
.red-v { color: var(--red); font-weight: 700; }
.yes-v { color: #16a34a; font-weight: 700; }
.no-v  { color: var(--t3); }

/* ============================================================
   TESTIMONIALS  — Blumpo-style dual marquee wall
   ============================================================ */
.testimonials-section {
  background: var(--cream-2);
  overflow: hidden;
}
.testi-marquee-wrap {
  margin-top: 52px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.testi-track {
  display: flex;
  gap: 0;
  width: max-content;
  will-change: transform;
}
.testi-track.trow-fwd { animation: tmarquee-fwd 40s linear infinite; }
.testi-track.trow-rev { animation: tmarquee-rev 48s linear infinite; }
@keyframes tmarquee-fwd {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}
@keyframes tmarquee-rev {
  from { transform: translateX(-50%); }
  to   { transform: translateX(0); }
}
@media (prefers-reduced-motion: reduce) {
  .testi-track { animation: none !important; }
}
.testi-card {
  background: var(--white);
  border: 1px solid var(--bdr);
  border-radius: var(--r-lg);
  padding: 24px 26px 22px;
  width: 340px;
  flex-shrink: 0;
  margin: 0 10px;
  transition: box-shadow 0.2s, border-color 0.2s;
}
.testi-card:hover {
  box-shadow: 0 6px 32px rgba(160,90,80,0.10);
  border-color: var(--rose);
}
.testi-stars { color: var(--red); font-size: 13px; letter-spacing: 2px; margin-bottom: 12px; }
.testi-quote { font-family: var(--serif); font-size: 14.5px; font-style: italic; color: var(--t1); line-height: 1.65; margin-bottom: 18px; }
.testi-author { display: flex; align-items: center; gap: 11px; }
.testi-avatar {
  width: 42px; height: 42px; border-radius: 50%;
  overflow: hidden; flex-shrink: 0;
  border: 2px solid var(--bdr-hi);
}
.testi-avatar img, .testi-avatar svg { width: 100%; height: 100%; display: block; }
.testi-name { font-size: 13.5px; font-weight: 700; color: var(--t1); }
.testi-role { font-size: 12px; color: var(--t3); margin-top: 2px; }

/* ============================================================
   PLATFORM CAROUSEL  (Blumpo-style infinite marquee)
   ============================================================ */
.platform-strip {
  background: var(--white);
  border-top: 1px solid var(--bdr);
  border-bottom: 1px solid var(--bdr);
  padding: 36px 0;
  overflow: hidden;
}
.platform-strip-label {
  text-align: center;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.13em;
  text-transform: uppercase;
  color: var(--t3);
  margin-bottom: 26px;
}
.marquee-rows { display: flex; flex-direction: column; gap: 16px; }
.marquee-track {
  display: flex;
  gap: 0;
  width: max-content;
  will-change: transform;
}
.marquee-track.row-fwd  { animation: marquee-fwd  28s linear infinite; }
.marquee-track.row-rev  { animation: marquee-rev  34s linear infinite; }
@keyframes marquee-fwd {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}
@keyframes marquee-rev {
  from { transform: translateX(-50%); }
  to   { transform: translateX(0); }
}
@media (prefers-reduced-motion: reduce) {
  .marquee-track { animation: none !important; }
}
.platform-chip {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: var(--cream);
  border: 1.5px solid var(--bdr);
  border-radius: 100px;
  padding: 10px 22px;
  margin: 0 8px;
  white-space: nowrap;
  flex-shrink: 0;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.platform-chip:hover {
  border-color: var(--rose);
  box-shadow: 0 3px 14px var(--shadow);
}
.platform-chip svg {
  width: 20px;
  height: 20px;
  flex-shrink: 0;
}
.platform-chip span {
  font-size: 13px;
  font-weight: 700;
  color: var(--t2);
  letter-spacing: 0.01em;
}

/* ============================================================
   VALUE PROPS  —  3 pillars: efficiency · affiliate · passive
   ============================================================ */
.value-section {
  background: var(--cream-2);
  padding: 88px 0;
}
.value-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  margin-top: 56px;
}
.value-card {
  background: var(--white);
  border: 1px solid var(--bdr);
  border-radius: var(--r-xl);
  padding: 40px 32px 36px;
  position: relative;
  overflow: hidden;
  transition: box-shadow 0.22s, transform 0.22s;
}
.value-card:hover { box-shadow: 0 8px 40px rgba(160,90,80,0.11); transform: translateY(-4px); }
.value-card::before {
  content: '';
  position: absolute;
  top: -30px; right: -30px;
  width: 100px; height: 100px;
  border-radius: 50%;
  opacity: 0.25;
}
.value-card.v1::before { background: var(--blush-2); }
.value-card.v2::before { background: #D9EDE0; }
.value-card.v3::before { background: #DBE8F5; }
.value-icon-wrap {
  width: 52px; height: 52px;
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 22px;
}
.v1 .value-icon-wrap { background: var(--blush); }
.v2 .value-icon-wrap { background: #D9EDE0; }
.v3 .value-icon-wrap { background: #DBE8F5; }
.value-icon-wrap svg { width: 26px; height: 26px; }
.value-num {
  font-family: var(--serif);
  font-size: 38px;
  font-weight: 800;
  line-height: 1;
  margin-bottom: 6px;
}
.v1 .value-num { color: var(--red); }
.v2 .value-num { color: #16a34a; }
.v3 .value-num { color: #2563EB; }
.value-title {
  font-family: var(--serif);
  font-size: 20px;
  font-weight: 700;
  color: var(--t1);
  margin-bottom: 10px;
  line-height: 1.25;
}
.value-body {
  font-size: 14px;
  color: var(--t2);
  line-height: 1.72;
}

/* ============================================================
   FAQ
   ============================================================ */
.faq-section { background: var(--cream); }
.faq-wrap { max-width: 740px; margin: 0 auto; }
.faq-list { margin-top: 48px; }
.faq-item {
  border-bottom: 1px solid var(--bdr);
}
.faq-q {
  display: flex; align-items: center; justify-content: space-between;
  padding: 22px 0; cursor: pointer; user-select: none;
  font-size: 15.5px; font-weight: 700; color: var(--t1); gap: 16px;
  font-family: var(--sans);
}
.faq-arrow {
  width: 26px; height: 26px; border-radius: 50%; flex-shrink: 0;
  background: var(--cream-2);
  border: 1px solid var(--bdr);
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; color: var(--t2);
  transition: transform .26s, background .2s, color .2s;
}
.faq-item.open .faq-arrow {
  transform: rotate(180deg);
  background: var(--blush);
  color: var(--red);
  border-color: var(--blush-2);
}
.faq-a {
  max-height: 0; overflow: hidden;
  transition: max-height .34s ease, padding-bottom .34s;
  font-size: 14.5px; color: var(--t2); line-height: 1.72;
}
.faq-item.open .faq-a { max-height: 260px; padding-bottom: 22px; }

/* ============================================================
   CTA SECTION
   ============================================================ */
.cta-section {
  background: var(--cream-2);
  border-top: 1px solid var(--bdr);
  text-align: center;
  padding: 100px 0;
  position: relative;
  overflow: hidden;
}
/* Decorative circle behind */
.cta-section::before {
  content: '';
  position: absolute;
  bottom: -120px; left: 50%;
  transform: translateX(-50%);
  width: 560px; height: 560px;
  background: var(--blush);
  border-radius: 50%;
  opacity: 0.5;
  pointer-events: none;
}
.cta-title {
  font-family: var(--serif);
  font-size: clamp(30px, 5vw, 52px);
  font-weight: 800; letter-spacing: -0.015em;
  max-width: 640px; margin: 0 auto 18px; line-height: 1.15;
  color: var(--t1);
  position: relative; z-index: 1;
}
.cta-title em { font-style: italic; color: var(--red); }
.cta-sub {
  position: relative; z-index: 1;
  margin: 0 auto 40px;
}
.cta-ctas { position: relative; z-index: 1; display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

/* ============================================================
   FOOTER
   ============================================================ */
footer {
  background: var(--white);
  border-top: 1px solid var(--bdr);
  padding: 60px 0 28px;
}
.footer-grid {
  display: grid;
  grid-template-columns: 2.2fr 1fr 1fr 1fr 1fr;
  gap: 48px;
  margin-bottom: 48px;
}
.footer-brand .logo { margin-bottom: 14px; }
.footer-brand p { font-size: 13.5px; color: var(--t2); line-height: 1.65; max-width: 210px; }
.footer-col h5 {
  font-size: 11px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.1em;
  color: var(--t3); margin-bottom: 16px;
}
.footer-col li { margin-bottom: 10px; }
.footer-col li a { font-size: 13.5px; color: var(--t2); transition: color .15s; }
.footer-col li a:hover { color: var(--red); }
.footer-bottom {
  border-top: 1px solid var(--bdr);
  padding-top: 22px;
  display: flex; align-items: center; justify-content: space-between;
  font-size: 12.5px; color: var(--t3);
}
.footer-heart { color: var(--red); }

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 960px) {
  .nav-links { display: none; }
  .stats-grid { grid-template-columns: repeat(2, 1fr); }
  .features-grid { grid-template-columns: repeat(2, 1fr); }
  .pricing-grid { grid-template-columns: 1fr; max-width: 440px; margin: 0 auto; }
  .testi-grid { grid-template-columns: 1fr; max-width: 440px; margin: 36px auto 0; }
  .footer-grid { grid-template-columns: 1fr 1fr; }
  .pin-preview { grid-template-columns: repeat(2, 1fr); }
  .value-grid { grid-template-columns: 1fr; max-width: 440px; margin: 36px auto 0; }
}
@media (max-width: 600px) {
  .hero { padding: 72px 0 52px; }
  .section { padding: 68px 0; }
  .hero::before, .hero::after { display: none; }
  .features-grid { grid-template-columns: 1fr; }
  .footer-grid { grid-template-columns: 1fr; }
  .footer-bottom { flex-direction: column; gap: 8px; text-align: center; }
}
</style>
</head>
